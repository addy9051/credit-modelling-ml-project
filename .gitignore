# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# ---- Virtual environments ----
.venv/
venv/
env/

# ---- uv ----
# uv.lock IS committed (reproducible installs); the cache is not.
.uv/

# ---- Tooling caches ----
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/
htmlcov/
.coverage
coverage.xml

# ---- Secrets / env ----
.env
*.pem
*.key

# ---- Data (PII — never commit) ----
data/raw/**
data/processed/**
data/features/**
data/synthetic/**
!data/**/.gitkeep

# ---- ML artifacts ----
mlruns/
mlartifacts/
*.joblib
*.pkl
*.onnx
reports/*.html
reports/*.pdf
!reports/.gitkeep

# ---- dbt ----
pipelines/dbt/target/
pipelines/dbt/dbt_packages/
pipelines/dbt/logs/

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.vscode/
.idea/
