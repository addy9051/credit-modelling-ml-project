# Copy to .env (git-ignored) and fill in. Used by docker-compose and production config.

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:mlflow@postgres:5432/mlflow
MLFLOW_ARTIFACT_ROOT=/mlartifacts

# --- PostgreSQL (MLflow backend + Feast offline) ---
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=change_me
POSTGRES_DB=mlflow

# --- Redis (Feast online store) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- API auth ---
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256

# --- Decentro bureau API (bureau_connector.py) ---
# Sandbox keys: sign up free at https://decentro.tech/signup/
# Leave blank + set DECENTRO_USE_FIXTURES=true for local dev without a key.
DECENTRO_CLIENT_ID=
DECENTRO_CLIENT_SECRET=
DECENTRO_ENV=sandbox              # sandbox | production
DECENTRO_TIMEOUT=30
DECENTRO_USE_FIXTURES=true        # set false once you have real sandbox credentials

# --- Other external data APIs ---
GSTN_API_KEY=
ACCOUNT_AGGREGATOR_CLIENT_ID=
ACCOUNT_AGGREGATOR_CLIENT_SECRET=

# --- Alerting ---
SLACK_WEBHOOK_URL=
